{
  "name": "jcsqe-study-app",
  "version": "1.2.26",
  "description": "JCSQE初級 合格対策学習アプリ",
  "private": true,
  "scripts": {
    "start": "http-server . -p 5173 -o -c-1",
    "serve": "http-server . -p 5173 -c-1",
    "test": "node --test && node scripts/validate-questions.js && node scripts/check-no-secrets-in-git.js",
    "validate": "node scripts/validate-questions.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs",
    "bug:report": "gh issue create --body-file scripts/bug-report-body.md --label bug",
    "bug:report:web": "gh issue create --web",
    "bug:sync": "node scripts/sync-bug-issues.js",
    "cf:login": "npx wrangler@3 login",
    "cf:pages:create": "npx wrangler@3 pages project create jcsqe-study-app --production-branch=master && npx wrangler@3 pages project create jcsqe-study-app-staging --production-branch=staging"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1"
  }
}
