{
  "name": "jcsqe-study-app",
  "version": "1.2.6",
  "description": "JCSQE初級 合格対策学習アプリ",
  "private": true,
  "scripts": {
    "start": "http-server . -p 5173 -o -c-1",
    "serve": "http-server . -p 5173 -c-1",
    "test": "node --test && node scripts/validate-questions.js",
    "validate": "node scripts/validate-questions.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "bug:report": "gh issue create --body-file scripts/bug-report-body.md --label bug",
    "bug:report:web": "gh issue create --web",
    "bug:sync": "node scripts/sync-bug-issues.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "http-server": "^14.1.1"
  }
}
